{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

eval "$(/opt/homebrew/bin/brew shellenv zsh)"

{{ with .packages.darwin.brews -}}
{{ range . -}}
brew install {{ . | quote }}
{{ end -}}
{{ end -}}
{{ with .packages.darwin.casks -}}
{{ range . -}}
brew install --cask {{ . | quote }}
{{ end -}}
{{ end -}}
{{ end -}}